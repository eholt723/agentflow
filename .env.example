# AgentFlow Environment Variables
# Copy this file to .env and fill in your values

# --- Inference Service ---
INFERENCE_BASE_URL=http://localhost:8080
INFERENCE_MODEL=local-model
INFERENCE_TIMEOUT_SECONDS=30

# --- Application ---
LOG_LEVEL=INFO
DEBUG=false

# --- n8n Workflow Automation ---
N8N_WEBHOOK_URL=
N8N_ENABLED=false
